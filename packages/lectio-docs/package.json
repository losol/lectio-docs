{
  "name": "@eventuras/lectio-docs",
  "version": "0.2.0",
  "description": "Headless, framework-agnostic toolkit for collecting documentation scattered across a repository into one content source, with full-text search.",
  "keywords": [
    "documentation",
    "docs",
    "monorepo",
    "markdown",
    "search",
    "orama"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/losol/lectio-docs.git",
    "directory": "packages/lectio-docs"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./content": {
      "types": "./dist/content/index.d.ts",
      "import": "./dist/content/index.js"
    },
    "./search": {
      "types": "./dist/search/index.d.ts",
      "import": "./dist/search/index.js"
    },
    "./build-index": {
      "types": "./dist/search/build-index.d.ts",
      "import": "./dist/search/build-index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "^6.0.2",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3"
  }
}
