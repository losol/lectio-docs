      "optional": true
    }
  },
  "devDependencies": {
    "@eventuras/ratio-ui": "^2.13.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^19.2.5",
    "typescript": "^7.0.2",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3"
  }
